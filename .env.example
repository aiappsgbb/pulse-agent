# ============================================================================
# Pulse Agent — Environment Configuration
# ============================================================================
# Copy this file to .env if you need overrides. In most cases you don't —
# Pulse auto-detects paths from the OneDriveCommercial env var (set by the
# OneDrive for Business sync client on Windows).
#
# The .env file is gitignored — your secrets stay local.
# ============================================================================

# ---------------------------------------------------------------------------
# OPTIONAL — Override PULSE_HOME (where Pulse stores all data).
# Auto-detected: $OneDriveCommercial/Documents/Pulse
# Only set this if your OneDrive path is non-standard.
# ---------------------------------------------------------------------------
# PULSE_HOME=$USERPROFILE/OneDrive - Microsoft/Documents/Pulse

# ---------------------------------------------------------------------------
# OPTIONAL — Override which standing-instructions YAML to load.
# Auto-detected: $PULSE_HOME/standing-instructions.yaml → repo fallback.
# Useful for running a second daemon instance with different config.
# ---------------------------------------------------------------------------
# PULSE_CONFIG=config/standing-instructions-alpha.yaml
